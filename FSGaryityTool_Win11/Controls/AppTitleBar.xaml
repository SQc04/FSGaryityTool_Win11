<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="FSGaryityTool_Win11.Controls.AppTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:FSGaryityTool_Win11.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="AppTitleBarUserControl"
             Height="48"
             Margin="0,0,0,0"
             VerticalAlignment="Top"
             mc:Ignorable="d">


    <Grid x:Name="AppTitleBarRootGrid" Margin="0,0,0,0">
        <Grid.Resources>
            <Style x:Key="TitleBadgeStyle" TargetType="Border">
                <Setter Property="Height" Value="16" />
                <Setter Property="Margin" Value="3,2,0,0" />
                <Setter Property="CornerRadius" Value="2" />
                <Setter Property="Opacity" Value="0.9" />
            </Style>
            <Style x:Key="TitleBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="Margin" Value="3,0,3,0" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="Black" />
                <!--  {ThemeResource TextOnAccentFillColorPrimaryBrush}  -->
            </Style>
        </Grid.Resources>

        <StackPanel Grid.Row="0" Grid.Column="2" Canvas.ZIndex="10" Orientation="Horizontal">
            <Image x:Name="TitleBarIcon"
                   Width="20"
                   Height="20"
                   Margin="0,2,0,0"
                   HorizontalAlignment="Left"
                   Source="{x:Bind AppLogoSource}"
                   Stretch="Fill" />

            <TextBlock x:Name="TitleBarTextBlock" Margin="8,2,1,0" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind AppTitleName}" />

            <!--  开发/测试阶段  -->
            <Border x:Name="TitleDev" Background="#82CD32" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Dev" />
            </Border>
            <Border x:Name="TitleAlpha" Background="#FF8C00" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Alpha" />
            </Border>
            <Border x:Name="TitleBeta" Background="#00CED1" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Beta" />
            </Border>
            <Border x:Name="TitleCanary" Background="#FFD700" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Canary" />
            </Border>
            <Border x:Name="TitlePreview" Background="#DB7093" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Preview" />
            </Border>
            <Border x:Name="TitleRC" Background="#F08080" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="RC" />
            </Border>
            <Border x:Name="TitleNightly" Background="#494970" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Nightly" />
            </Border>
            <Border x:Name="TitleStable" Background="#2E8B57" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Stable" />
            </Border>

            <!--  用户/社区相关  -->
            <Border x:Name="TitleInsider" Background="#87CEEB" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Insider" />
            </Border>
            <Border x:Name="TitleCommunity" Background="#32CD32" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Community" />
            </Border>
            <Border x:Name="TitleEnterprise" Background="#228B92" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Enterprise" />
            </Border>
            <Border x:Name="TitlePro" Background="#DA4560" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Pro" />
            </Border>
            <Border x:Name="TitleCustom" Background="#9370DB" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Custom" />
            </Border>
            <Border x:Name="TitleLegacy" Background="#C0C0C0" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Legacy" />
            </Border>

            <!--  特殊用途  -->
            <Border x:Name="TitleExperimental" Background="#778899" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Experimental" />
            </Border>
            <Border x:Name="TitleDebug" Background="#7B68EE" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Debug" />
            </Border>
            <Border x:Name="TitleSandbox" Background="#5BA583" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Sandbox" />
            </Border>
            <Border x:Name="TitlePrototype" Background="#FF69B4" Style="{StaticResource TitleBadgeStyle}" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleBadgeTextStyle}" Text="Prototype" />
            </Border>

            <StackPanel.Transitions>
                <TransitionCollection>
                    <RepositionThemeTransition />
                </TransitionCollection>
            </StackPanel.Transitions>
        </StackPanel>
    </Grid>
</UserControl>
