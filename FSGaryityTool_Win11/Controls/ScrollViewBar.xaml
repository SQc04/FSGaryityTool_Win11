<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="FSGaryityTool_Win11.Controls.ScrollViewBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:FSGaryityTool_Win11.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:win2Dcanvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!--  动画时间与偏移资源  -->
        <x:Double x:Key="ScrollViewBarThumbOffset">2</x:Double>
        <x:String x:Key="ScrollViewBarContractBeginTime">0:0:0.0</x:String>
        <x:Double x:Key="ScrollViewBarHorizontalThumbMinHeight">24</x:Double>
        <x:Double x:Key="ScrollViewBarVerticalThumbMinHeight">24</x:Double>
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <!--  横向滚动条  -->
        <Grid x:Name="HorizontalRoot" Margin="2" CornerRadius="6" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.ColumnSpan="4" Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" />

            <RepeatButton x:Name="RepeatButtonLeft"
                          Grid.Column="0"
                          Width="18"
                          Margin="1"
                          Padding="-12"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          BorderThickness="0"
                          Click="RepeatButtonLeft_Click">
                <FontIcon FontSize="9" Foreground="{ThemeResource ControlStrongFillColorDefault}" Glyph="&#xEDD9;" />
            </RepeatButton>
            <RepeatButton x:Name="RepeatButtonRight"
                          Grid.Column="3"
                          Width="18"
                          Margin="1"
                          Padding="-12"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          BorderThickness="0"
                          Click="RepeatButtonRight_Click">
                <FontIcon FontSize="9" Foreground="{ThemeResource ControlStrongFillColorDefault}" Glyph="&#xEDDA;" />
            </RepeatButton>

            <Border x:Name="HorizontalScrollViewBarBorder"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Margin="0,4"
                    BorderBrush="{ThemeResource TextFillColorTertiaryBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Opacity="{x:Bind WaveGridBorderOpacity, Mode=OneWay}" />

            <win2Dcanvas:CanvasControl Grid.Column="1" Grid.ColumnSpan="2" Margin="0,4" IsHitTestVisible="False" />
            <win2Dcanvas:CanvasControl Grid.Column="1" Grid.ColumnSpan="2" Margin="0,4" IsHitTestVisible="False" />

            <Border Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Height="1.5"
                    Margin="6,0"
                    BorderBrush="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    BorderThickness="2"
                    Opacity="{x:Bind WaveGridBorderOpacity, Mode=OneWay}"
                    Visibility="Collapsed" />

            <Grid x:Name="AllHorizontalThumb" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Thumb x:Name="HorizontalThumbLeft"
                       Grid.Column="0"
                       MinWidth="8"
                       Margin="0,4"
                       Background="{ThemeResource ControlStrokeColorOnAccentDisabledBrush}"
                       BorderBrush="{ThemeResource ControlStrongFillColorDefault}"
                       BorderThickness="1.5,1.5,0,1.5"
                       CornerRadius="4,0,0,4" />

                <Thumb x:Name="HorizontalThumb"
                       Grid.Column="1"
                       MinWidth="24"
                       Margin="0,4"
                       Background="{ThemeResource ControlStrokeColorOnAccentDisabledBrush}"
                       BorderBrush="{ThemeResource ControlStrongFillColorDefault}"
                       BorderThickness="1"
                       CornerRadius="0"
                       IsHitTestVisible="True"
                       ManipulationMode="None"
                       PointerMoved="Thumb_PointerMoved"
                       PointerPressed="Thumb_PointerPressed"
                       PointerReleased="Thumb_PointerReleased" />

                <Thumb x:Name="HorizontalThumbRight"
                       Grid.Column="2"
                       MinWidth="8"
                       Margin="0,4"
                       Background="{ThemeResource ControlStrokeColorOnAccentDisabledBrush}"
                       BorderBrush="{ThemeResource ControlStrongFillColorDefault}"
                       BorderThickness="0,1.5,1.5,1.5"
                       CornerRadius="0,4,4,0" />

                <Grid.RenderTransform>
                    <TranslateTransform x:Name="HorizontalThumbTransform" X="{x:Bind ScrollOffset, Mode=OneWay}" />
                </Grid.RenderTransform>
            </Grid>
        </Grid>

        <!--  纵向滚动条  -->
        <Grid x:Name="VerticalRoot" Margin="2" CornerRadius="6" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="4" Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" />
            <RepeatButton x:Name="RepeatButtonUp"
                          Grid.Row="0"
                          Height="18"
                          Margin="1"
                          Padding="-12"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          BorderThickness="0"
                          Click="RepeatButtonUp_Click">
                <FontIcon FontSize="9" Foreground="{ThemeResource ControlStrongFillColorDefault}" Glyph="&#xEDDB;" />
            </RepeatButton>
            <RepeatButton x:Name="RepeatButtonDown"
                          Grid.Row="3"
                          Height="18"
                          Margin="1"
                          Padding="-12"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          BorderThickness="0"
                          Click="RepeatButtonDown_Click">
                <FontIcon FontSize="9" Foreground="{ThemeResource ControlStrongFillColorDefault}" Glyph="&#xEDDC;" />
            </RepeatButton>

            <Border x:Name="VerticalScrollViewBarBorder"
                    Grid.Row="1"
                    Grid.RowSpan="2"
                    Margin="4,0"
                    BorderBrush="{ThemeResource TextFillColorTertiaryBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Opacity="{x:Bind WaveGridBorderOpacity, Mode=OneWay}" />

            <win2Dcanvas:CanvasControl Grid.Row="1" Grid.RowSpan="2" Margin="4,0" IsHitTestVisible="False" />
            <win2Dcanvas:CanvasControl Grid.Row="1" Grid.RowSpan="2" Margin="4,0" IsHitTestVisible="False" />

            <Border Grid.Row="1"
                    Grid.RowSpan="2"
                    Width="1.5"
                    Margin="0,6"
                    BorderBrush="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    BorderThickness="2"
                    Opacity="{x:Bind WaveGridBorderOpacity, Mode=OneWay}"
                    Visibility="Collapsed" />

            <Grid x:Name="AllVerticalThumb" Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Thumb x:Name="VerticalThumbTop"
                       Grid.Row="0"
                       MinHeight="8"
                       Margin="4,0"
                       Background="{ThemeResource ControlStrokeColorOnAccentDisabledBrush}"
                       BorderBrush="{ThemeResource ControlStrongFillColorDefault}"
                       BorderThickness="1.5,1.5,1.5,0"
                       CornerRadius="4,4,0,0"
                       PointerMoved="ThumbTop_PointerMoved"
                       PointerPressed="ThumbTop_PointerPressed"
                       PointerReleased="ThumbTop_PointerReleased" />

                <Thumb x:Name="VerticalThumb"
                       Grid.Row="1"
                       MinHeight="24"
                       Margin="4,0"
                       Background="{ThemeResource ControlStrokeColorOnAccentDisabledBrush}"
                       BorderBrush="{ThemeResource ControlStrongFillColorDefault}"
                       BorderThickness="1.5,1"
                       CornerRadius="0"
                       IsHitTestVisible="True"
                       ManipulationMode="None"
                       PointerMoved="Thumb_PointerMoved"
                       PointerPressed="Thumb_PointerPressed"
                       PointerReleased="Thumb_PointerReleased" />

                <Thumb x:Name="VerticalThumbBottom"
                       Grid.Row="2"
                       MinHeight="8"
                       Margin="4,0"
                       Background="{ThemeResource ControlStrokeColorOnAccentDisabledBrush}"
                       BorderBrush="{ThemeResource ControlStrongFillColorDefault}"
                       BorderThickness="1.5,0,1.5,1.5"
                       CornerRadius="0,0,4,4"
                       PointerMoved="ThumbBottom_PointerMoved"
                       PointerPressed="ThumbBottom_PointerPressed"
                       PointerReleased="ThumbBottom_PointerReleased" />

                <Grid.RenderTransform>
                    <TranslateTransform x:Name="VerticalThumbTransform" Y="{x:Bind ScrollOffset, Mode=OneWay}" />
                </Grid.RenderTransform>
            </Grid>
        </Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="OrientationStates">
                <VisualState x:Name="Horizontal">
                    <Storyboard>
                        <DoubleAnimationUsingKeyFrames BeginTime="{StaticResource ScrollViewBarContractBeginTime}" Storyboard.TargetName="HorizontalThumbTransform" Storyboard.TargetProperty="X">
                            <SplineDoubleKeyFrame KeySpline="0,0,0,1" KeyTime="0" Value="{StaticResource ScrollViewBarThumbOffset}" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames BeginTime="{StaticResource ScrollBarContractBeginTime}" EnableDependentAnimation="True" Storyboard.TargetName="HorizontalThumb" Storyboard.TargetProperty="Width">
                            <SplineDoubleKeyFrame KeySpline="0,0,0,1" KeyTime="0" Value="{StaticResource ScrollViewBarHorizontalThumbMinHeight}" />
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="Vertical">
                    <Storyboard>
                        <DoubleAnimationUsingKeyFrames BeginTime="{StaticResource ScrollViewBarContractBeginTime}" Storyboard.TargetName="VerticalThumbTransform" Storyboard.TargetProperty="Y">
                            <SplineDoubleKeyFrame KeySpline="0,0,0,1" KeyTime="0" Value="{StaticResource ScrollViewBarThumbOffset}" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames BeginTime="{StaticResource ScrollBarContractBeginTime}" EnableDependentAnimation="True" Storyboard.TargetName="VerticalThumb" Storyboard.TargetProperty="Height">
                            <SplineDoubleKeyFrame KeySpline="0,0,0,1" KeyTime="0" Value="{StaticResource ScrollViewBarVerticalThumbMinHeight}" />
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</UserControl>
