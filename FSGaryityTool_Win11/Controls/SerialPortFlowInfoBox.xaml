<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="FSGaryityTool_Win11.Controls.SerialPortFlowInfoBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:FSGaryityTool_Win11.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:win2dcanvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
             PointerEntered="UserControl_PointerEntered"
             PointerExited="UserControl_PointerExited"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <Color x:Key="SystemControlBackgroundLightColor">#90FFFFFF</Color>
            <Color x:Key="SystemControlBackgroundDarkColor">#44252525</Color>

            <Color x:Key="SystemBorderBrushLightColor">#15252525</Color>
            <Color x:Key="SystemBorderBrushDarkColor">#15FFFFFF</Color>

            <Color x:Key="RxBoxButtonBorderBackgroundLightColor">#1F252525</Color>
            <Color x:Key="RxBoxButtonBorderBackgroundDarkColor">#248F8F8F</Color>

            <Storyboard x:Name="PointerEnteredStoryboard">
                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ClearSerialInfoButton" Storyboard.TargetProperty="Visibility">
                    <DiscreteObjectKeyFrame KeyTime="0:0:0">
                        <DiscreteObjectKeyFrame.Value>
                            <Visibility>Visible</Visibility>
                        </DiscreteObjectKeyFrame.Value>
                    </DiscreteObjectKeyFrame>
                </ObjectAnimationUsingKeyFrames>
            </Storyboard>
            <Storyboard x:Name="PointerExitedStoryboard">
                <ObjectAnimationUsingKeyFrames BeginTime="0:0:0" Storyboard.TargetName="ClearSerialInfoButton" Storyboard.TargetProperty="Visibility">
                    <DiscreteObjectKeyFrame KeyTime="0:0:0.25">
                        <DiscreteObjectKeyFrame.Value>
                            <Visibility>Collapsed</Visibility>
                        </DiscreteObjectKeyFrame.Value>
                    </DiscreteObjectKeyFrame>
                </ObjectAnimationUsingKeyFrames>
            </Storyboard>


            <ResourceDictionary.ThemeDictionaries>
                <!--  浅色模式的AcrylicBrush  -->
                <ResourceDictionary x:Key="Light">
                    <AcrylicBrush x:Key="CustomAcrylicBrush" FallbackColor="{StaticResource SystemControlBackgroundLightColor}" TintColor="#FCFCFC" TintOpacity="0.0" />
                    <SolidColorBrush x:Key="CustomBoxSolidColorBrush" Color="{StaticResource SystemControlBackgroundLightColor}" />
                    <SolidColorBrush x:Key="CustomBoxElevationBorderBrush" Color="{StaticResource SystemBorderBrushLightColor}" />
                </ResourceDictionary>
                <!--  深色模式的AcrylicBrush  -->
                <ResourceDictionary x:Key="Dark">
                    <AcrylicBrush x:Key="CustomAcrylicBrush" FallbackColor="{StaticResource SystemControlBackgroundDarkColor}" TintColor="#2C2C2C" TintOpacity="0.15" />
                    <SolidColorBrush x:Key="CustomBoxSolidColorBrush" Color="{StaticResource SystemControlBackgroundDarkColor}" />
                    <SolidColorBrush x:Key="CustomBoxElevationBorderBrush" Color="{StaticResource SystemBorderBrushDarkColor}" />

                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid x:Name="RootGrid">
        <!--
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <RepositionThemeTransition />
            </TransitionCollection>
        </Grid.ChildrenTransitions>-->
        <Border x:Name="SerialInfoBorder"
                Grid.Row="0"
                Margin="0,0,0,6"
                Background="{ThemeResource CustomBoxSolidColorBrush}"
                BorderBrush="{ThemeResource CustomBoxElevationBorderBrush}"
                BorderThickness="3"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <Border x:Name="InfoBorder"
                        Grid.Column="0"
                        MinHeight="32"
                        Margin="3"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CustomBoxElevationBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock x:Name="InfoNameTextBlock"
                               Width="36"
                               Margin="0"
                               VerticalAlignment="Center"
                               Text="{x:Bind InfoName, Mode=OneWay}"
                               TextAlignment="Center" />
                    <Border.BackgroundTransition>
                        <BrushTransition />
                    </Border.BackgroundTransition>
                </Border>
                <Border Grid.Column="1" Width="1" Margin="1,3,1,3" Background="{ThemeResource ControlStrongStrokeColorDisabledBrush}" />
                <Border Grid.Column="2" Margin="0" CornerRadius="4">
                    <local:WaveformView x:Name="OscilloscopeWaveformView"
                                        ColumnTickCount="6"
                                        Data="{x:Bind WaveformSources, Mode=OneWay}"
                                        MaxColumnTickCount="16"
                                        MaxHorizontalValue="{x:Bind WaveViewWidth, Mode=OneWay}"
                                        MaxRowTickCount="16"
                                        MaxVerticalValue="1"
                                        MinColumnTickCount="0"
                                        MinHorizontalValue="0"
                                        MinRowTickCount="0"
                                        MinVerticalValue="0"
                                        RowTickCount="2"
                                        RowTickLineWidth="0"
                                        ViewCenterPointMode="Auto"
                                        WaveGridBorderBrush="{ThemeResource CustomBoxElevationBorderBrush}"
                                        WaveGridBorderMargin="0"
                                        WaveGridBorderOpacity="1"
                                        WaveGridBorderThickness="1"
                                        WaveGridBorderTickThickness="0" />
                </Border>

                <win2dcanvas:CanvasControl />

                <Button x:Name="ClearSerialInfoButton"
                        Grid.Column="3"
                        Width="32"
                        Height="32"
                        Margin="0,0,3,0"
                        Background="Transparent"
                        BorderThickness="1"
                        Click="ClearSerialInfoButton_Click"
                        Visibility="Collapsed">
                    <FontIcon Margin="-8" FontSize="14" Glyph="&#xE711;" />
                </Button>
            </Grid>
        </Border>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="PointerStates">
                <VisualState x:Name="PointerEntered">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ClearSerialInfoButton" Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                <DiscreteObjectKeyFrame.Value>
                                    <Visibility>Visible</Visibility>
                                </DiscreteObjectKeyFrame.Value>
                            </DiscreteObjectKeyFrame>
                        </ObjectAnimationUsingKeyFrames>
                        <DoubleAnimation Storyboard.TargetName="ClearSerialInfoButton" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.20" />
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="PointerExited">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames BeginTime="0:0:0" Storyboard.TargetName="ClearSerialInfoButton" Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0:0:0.25">
                                <DiscreteObjectKeyFrame.Value>
                                    <Visibility>Collapsed</Visibility>
                                </DiscreteObjectKeyFrame.Value>
                            </DiscreteObjectKeyFrame>
                        </ObjectAnimationUsingKeyFrames>
                        <DoubleAnimation Storyboard.TargetName="ClearSerialInfoButton" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.20" />
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</UserControl>
