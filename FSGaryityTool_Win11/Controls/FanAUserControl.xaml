<UserControl x:Class="FSGaryityTool_Win11.Controls.FanAUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fsControl="using:FSGaryityTool_Win11.Controls"
             xmlns:local="using:FSGaryityTool_Win11.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <Color x:Key="SystemControlBackgroundLightColor">#90FFFFFF</Color>
            <Color x:Key="SystemControlBackgroundDarkColor">#44252525</Color>

            <Color x:Key="SystemBorderBrushLightColor">#15252525</Color>
            <Color x:Key="SystemBorderBrushDarkColor">#15FFFFFF</Color>

            <Color x:Key="RxBoxButtonBorderBackgroundLightColor">#1F252525</Color>
            <Color x:Key="RxBoxButtonBorderBackgroundDarkColor">#248F8F8F</Color>

            <ResourceDictionary.ThemeDictionaries>
                <!--  ǳɫģʽ��AcrylicBrush  -->
                <ResourceDictionary x:Key="Light">
                    <AcrylicBrush x:Key="CustomAcrylicBrush" FallbackColor="{StaticResource SystemControlBackgroundLightColor}" TintColor="#FCFCFC" TintOpacity="0.0" />
                    <SolidColorBrush x:Key="CustomBoxSolidColorBrush" Color="{StaticResource SystemControlBackgroundLightColor}" />
                    <SolidColorBrush x:Key="CustomBoxElevationBorderBrush" Color="{StaticResource SystemBorderBrushLightColor}" />
                </ResourceDictionary>
                <!--  ��ɫģʽ��AcrylicBrush  -->
                <ResourceDictionary x:Key="Dark">
                    <AcrylicBrush x:Key="CustomAcrylicBrush" FallbackColor="{StaticResource SystemControlBackgroundDarkColor}" TintColor="#2C2C2C" TintOpacity="0.15" />
                    <SolidColorBrush x:Key="CustomBoxSolidColorBrush" Color="{StaticResource SystemControlBackgroundDarkColor}" />
                    <SolidColorBrush x:Key="CustomBoxElevationBorderBrush" Color="{StaticResource SystemBorderBrushDarkColor}" />

                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <StackPanel Margin="0" VerticalAlignment="Top" Orientation="Vertical">
            <TextBlock x:Name="FanNameTextBlock" Margin="0">
                <Run Text="{x:Bind FanName, Mode=OneWay}" />
                <Run Text="FAN" />
            </TextBlock>
            <Border x:Name="FanControlRadialGauge" MinHeight="300" Margin="0,3,0,3" Background="Transparent" CornerRadius="4">
                <Grid Padding="-6,-6,-5,-6">

                    <fsControl:CustomWrapPanel>

                        <Grid Width="312" Height="312" Padding="6">
                            <Border Background="{ThemeResource CustomBoxSolidColorBrush}" BorderBrush="{ThemeResource CustomBoxElevationBorderBrush}" BorderThickness="3" CornerRadius="4">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <FontIcon Margin="12" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="27" Glyph="&#xE950;" />
                                    <toolkit:RadialGauge x:Name="FanRpmRadialGauge"
                                                         Margin="39"
                                                         IsInteractive="False"
                                                         Maximum="8000"
                                                         NeedleLength="0"
                                                         ScaleWidth="8"
                                                         TickSpacing="500"
                                                         TickWidth="0"
                                                         Value="{x:Bind FanRpm, Mode=TwoWay}" />
                                    <toolkit:RadialGauge x:Name="FanRadialGauge"
                                                         Margin="12"
                                                         Maximum="100"
                                                         TickPadding="21"
                                                         TickSpacing="5"
                                                         Value="{x:Bind FanControlPercentage, Mode=TwoWay}" />
                                    <TextBlock Margin="173,237,0,0" FontSize="12" Text="RPM" />
                                    <TextBlock Margin="166,259,0,0" Text="%" />
                                    <ToggleButton x:Name="CpuFanControlToggleButton"
                                                  Width="36"
                                                  Height="36"
                                                  Margin="6"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Top"
                                                  IsChecked="True">

                                        <FontIcon Margin="-4" Glyph="&#xE755;" />
                                    </ToggleButton>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Width="79" Height="312" Padding="6">
                            <Border Background="{ThemeResource CustomBoxSolidColorBrush}" BorderBrush="{ThemeResource CustomBoxElevationBorderBrush}" BorderThickness="3" CornerRadius="4">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="36" />
                                    </Grid.RowDefinitions>

                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Stretch">
                                        <Slider x:Name="Temp"
                                                Grid.Row="0"
                                                Margin="0,12,0,6"
                                                Maximum="120"
                                                Minimum="0"
                                                Orientation="Vertical"
                                                TickFrequency="20"
                                                TickPlacement="Outside"
                                                Value="{x:Bind Temperature, Mode=OneWay}" />
                                    </Grid>

                                    <TextBlock x:Name="TempText" Grid.Row="1" Margin="0,0,0,12" HorizontalAlignment="Center" FontSize="20">
                                        <Run Text="{x:Bind Temperature, Mode=OneWay}" />
                                        <Run Text="℃" />
                                    </TextBlock>

                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Height="312" MinWidth="200" Padding="6">
                            <Border Background="{ThemeResource CustomBoxSolidColorBrush}" BorderBrush="{ThemeResource CustomBoxElevationBorderBrush}" BorderThickness="3" CornerRadius="4" />
                        </Grid>

                        <Grid Height="312" MinWidth="390" Padding="6">
                            <Border Background="{ThemeResource CustomBoxSolidColorBrush}" BorderBrush="{ThemeResource CustomBoxElevationBorderBrush}" BorderThickness="3" CornerRadius="4">
                                <Grid />
                            </Border>
                        </Grid>
                    </fsControl:CustomWrapPanel>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
