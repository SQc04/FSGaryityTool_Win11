<Page x:Class="FSGaryityTool_Win11.Views.Pages.SerialPortPage.SerialPlotterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:FSGaryityTool_Win11.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:FSGaryityTool_Win11.Views.Pages.SerialPortPage"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
      NavigationCacheMode="Enabled"
      mc:Ignorable="d">
    <Page.Resources>
        <ResourceDictionary>
            <Color x:Key="SystemControlBackgroundLightColor">#90FFFFFF</Color>
            <Color x:Key="SystemControlBackgroundDarkColor">#44252525</Color>
            <ResourceDictionary.ThemeDictionaries>
                <!--  浅色模式的AcrylicBrush  -->
                <ResourceDictionary x:Key="Light">
                    <AcrylicBrush x:Key="CustomAcrylicBrush" FallbackColor="#F9F9F9" TintColor="#FCFCFC" TintOpacity="0.0" />
                    <SolidColorBrush x:Key="CustomRxBoxSolidColorBrush" Color="{ThemeResource SystemControlBackgroundLightColor}" />
                </ResourceDictionary>

                <!--  深色模式的AcrylicBrush  -->
                <ResourceDictionary x:Key="Dark">
                    <AcrylicBrush x:Key="CustomAcrylicBrush" FallbackColor="#2C2C2C" TintColor="#2C2C2C" TintOpacity="0.15" />
                    <SolidColorBrush x:Key="CustomRxBoxSolidColorBrush" Color="{ThemeResource SystemControlBackgroundDarkColor}" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="0,0,12,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions />

        <toolkit:GridSplitter Grid.Column="0" Margin="0,-6.05,0,0" HorizontalAlignment="Right" />

        <controls:WaveformView Grid.Column="0"
                               Margin="0,0,12,0"
                               Background="{ThemeResource CustomRxBoxSolidColorBrush}"
                               BorderBrush="{ThemeResource TextControlElevationBorderFocusedBrush}"
                               BorderThickness="3"
                               ColumnCenterTickLineBrush="{ThemeResource AccentTextFillColorPrimaryBrush}"
                               ColumnGridBorderSubTickCount="5"
                               ColumnTickCount="12"
                               ColumnTickLineBrush="{ThemeResource TextFillColorTertiaryBrush}"
                               CornerRadius="6"
                               CrossSize="8"
                               MaxColumnTickCount="8"
                               MaxRowTickCount="8"
                               MinColumnTickCount="4"
                               MinRowTickCount="4"
                               RowCenterTickLineBrush="{ThemeResource AccentTextFillColorPrimaryBrush}"
                               RowGridBorderSubTickCount="5"
                               RowTickCount="4"
                               RowTickLineBrush="{ThemeResource TextFillColorTertiaryBrush}"
                               WaveGridBorderBrush="{ThemeResource TextFillColorTertiaryBrush}"
                               WaveGridBorderLineStyle="Solid"
                               WaveGridBorderMargin="20"
                               WaveGridBorderSubTickThickness="-6,-6,-6,-6"
                               WaveGridBorderThickness="2,2,2,2"
                               WaveGridBorderTickThickness="-12,-12,-12,-12"
                               WaveGridTickLineStyle="Dash"
                               WaveGridTickMode="Cross" />

        <controls:BeyondTextBox Grid.Column="1" Margin="0,0,0,0" HorizontalAlignment="Stretch" />
    </Grid>
</Page>
