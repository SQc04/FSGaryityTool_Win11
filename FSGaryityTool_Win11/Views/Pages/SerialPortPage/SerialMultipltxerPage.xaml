<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="FSGaryityTool_Win11.Views.Pages.SerialPortPage.SerialMultipltxerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:FSGaryityTool_Win11.Views.Pages.SerialPortPage"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      NavigationCacheMode="Enabled"
      mc:Ignorable="d">

    <Grid>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <ToggleButton x:Name="ConnectToggleButton"
                          Grid.Row="1"
                          Grid.Column="1"
                          Width="100"
                          Height="36"
                          Margin="6"
                          Click="ConnectToggleButton_Click"
                          IsChecked="{x:Bind IsConnected, Mode=TwoWay}" />
            <ComboBox x:Name="SerialPortUpper"
                      Grid.Row="1"
                      Grid.Column="0"
                      Width="100"
                      Margin="6"
                      ItemsSource="{x:Bind Ports, Mode=OneWay}" />
            <ComboBox x:Name="SerialPortLower"
                      Grid.Row="1"
                      Grid.Column="2"
                      Width="100"
                      Margin="6"
                      ItemsSource="{x:Bind Ports, Mode=OneWay}" />
            <ComboBox x:Name="SerialPortUpperInput"
                      Grid.Row="2"
                      Grid.Column="0"
                      Width="100"
                      Margin="6"
                      ItemsSource="{x:Bind Ports, Mode=OneWay}" />
            <ComboBox x:Name="SerialPortLowerInput"
                      Grid.Row="2"
                      Grid.Column="2"
                      Width="100"
                      Margin="6"
                      ItemsSource="{x:Bind Ports, Mode=OneWay}" />

        </Grid>

    </Grid>
</Page>
