<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="FSGaryityTool_Win11.Views.Pages.SerialPortPage.SerialPortPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:FSGaryityTool_Win11.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:FSGaryityTool_Win11.Views.Pages.SerialPortPage"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <controls:BeyondTextBox x:Name="ReceiveDataBeyondTextBox" Grid.Row="0" Grid.Column="0" />

            <controls:BeyondTextBox x:Name="SendDataBeyondTextBox" Grid.Row="1" Grid.Column="0" />

        </Grid>
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
        </Grid>

        <StackPanel>
            <controls:SerialPortFlowInfoBox x:Name="SerialPortFlowInfoBoxDCD" InfoName="DCD" LogicAnalyzerBoxMaxTime="5" LogicalValue="False" />
            <controls:SerialPortFlowInfoBox x:Name="SerialPortFlowInfoBoxRING" InfoName="RI" LogicAnalyzerBoxMaxTime="5" LogicalValue="False" />
            <controls:SerialPortFlowInfoBox x:Name="SerialPortFlowInfoBoxDSR" InfoName="DSR" LogicAnalyzerBoxMaxTime="5" LogicalValue="False" />
            <controls:SerialPortFlowInfoBox x:Name="SerialPortFlowInfoBoxCTS" InfoName="CTS" LogicAnalyzerBoxMaxTime="5" LogicalValue="False" />
        </StackPanel>
        <controls:BeyondTextBox x:Name="LogBeyondTextBox" Grid.Row="1" Grid.Column="0" />
    </Grid>
</Page>
