<Page x:Class="FSGaryityTool_Win11.McuToolpage.ESP8266Tools"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:FSGaryityTool_Win11.McuToolpage"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      NavigationCacheMode="Enabled"
      mc:Ignorable="d">
    <Grid>
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="RstButton" Width="110" Margin="6" Click="RSTButton_Click">
                    Hardware RST
                </Button>

                <Button x:Name="DownloadButton" Width="100" Margin="6" Click="DownloadButton_Click">
                    Download
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
